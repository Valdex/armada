From: Sergio Lopez <slp@redhat.com>
Subject: [PATCH] input: allow 64-bit processes to opt into compat events

The compat variant of input syscalls is normally enabled only for 32-bit
tasks. Userspace CPU emulators such as FEX are 64-bit processes but need to
exchange the 32-bit input ABI with an emulated game. Add an explicit prctl
so those processes can opt in.

Based on ROCKNIX patch 0504 and rebased by Armada for Linux 7.0.11.

Signed-off-by: Sergio Lopez <slp@redhat.com>
---
 drivers/input/input-compat.c | 6 +++---
 drivers/input/input-compat.h | 2 +-
 include/linux/sched.h        | 5 +++++
 include/uapi/linux/prctl.h   | 5 +++++
 kernel/sys.c                 | 15 +++++++++++++++
 5 files changed, 29 insertions(+), 4 deletions(-)

diff --git a/drivers/input/input-compat.c b/drivers/input/input-compat.c
--- a/drivers/input/input-compat.c
+++ b/drivers/input/input-compat.c
@@ -14,7 +14,7 @@
 int input_event_from_user(const char __user *buffer,
 			  struct input_event *event)
 {
-	if (in_compat_syscall() && !COMPAT_USE_64BIT_TIME) {
+	if (current->compat_input || (in_compat_syscall() && !COMPAT_USE_64BIT_TIME)) {
 		struct input_event_compat compat_event;
 
 		if (copy_from_user(&compat_event, buffer,
@@ -38,7 +38,7 @@
 int input_event_to_user(char __user *buffer,
 			const struct input_event *event)
 {
-	if (in_compat_syscall() && !COMPAT_USE_64BIT_TIME) {
+	if (current->compat_input || (in_compat_syscall() && !COMPAT_USE_64BIT_TIME)) {
 		struct input_event_compat compat_event;
 
 		compat_event.sec = event->input_event_sec;
@@ -62,7 +62,7 @@
 int input_ff_effect_from_user(const char __user *buffer, size_t size,
 			      struct ff_effect *effect)
 {
-	if (in_compat_syscall()) {
+	if (current->compat_input || (in_compat_syscall() && !COMPAT_USE_64BIT_TIME)) {
 		struct ff_effect_compat *compat_effect;
 
 		if (size != sizeof(struct ff_effect_compat))
diff --git a/drivers/input/input-compat.h b/drivers/input/input-compat.h
--- a/drivers/input/input-compat.h
+++ b/drivers/input/input-compat.h
@@ -53,7 +53,7 @@ struct ff_effect_compat {
 
 static inline size_t input_event_size(void)
 {
-	return (in_compat_syscall() && !COMPAT_USE_64BIT_TIME) ?
+	return (current->compat_input || (in_compat_syscall() && !COMPAT_USE_64BIT_TIME)) ?
 		sizeof(struct input_event_compat) : sizeof(struct input_event);
 }
 
diff --git a/include/linux/sched.h b/include/linux/sched.h
--- a/include/linux/sched.h
+++ b/include/linux/sched.h
@@ -1636,6 +1636,11 @@ struct task_struct {
 #ifdef CONFIG_USER_EVENTS
 	struct user_event_mm		*user_event_mm;
 #endif
+	/*
+	 * Whether the task wants the 32-bit input ABI even when it is a
+	 * 64-bit process.
+	 */
+	bool				compat_input;
 
 #ifdef CONFIG_UNWIND_USER
 	struct unwind_task_info		unwind_info;
diff --git a/include/uapi/linux/prctl.h b/include/uapi/linux/prctl.h
--- a/include/uapi/linux/prctl.h
+++ b/include/uapi/linux/prctl.h
@@ -406,4 +406,9 @@
 # define PR_CFI_DISABLE		_BITUL(1)
 # define PR_CFI_LOCK		_BITUL(2)
 
+#define PR_GET_COMPAT_INPUT		0x63494e50
+#define PR_SET_COMPAT_INPUT		0x43494e50
+# define PR_SET_COMPAT_INPUT_DISABLE	0
+# define PR_SET_COMPAT_INPUT_ENABLE	1
+
 #endif /* _LINUX_PRCTL_H */
diff --git a/kernel/sys.c b/kernel/sys.c
--- a/kernel/sys.c
+++ b/kernel/sys.c
@@ -2907,6 +2907,21 @@ SYSCALL_DEFINE5(prctl, int, option, unsigned long, arg2, unsigned long, arg3,
 		if (arg3 & PR_CFI_LOCK && !(arg3 & PR_CFI_DISABLE))
 			error = arch_prctl_lock_branch_landing_pad_state(me);
 		break;
+	case PR_GET_COMPAT_INPUT:
+		if (arg2 || arg3 || arg4 || arg5)
+			return -EINVAL;
+		error = current->compat_input;
+		break;
+	case PR_SET_COMPAT_INPUT:
+		if (arg3 || arg4 || arg5)
+			return -EINVAL;
+		if (arg2 == PR_SET_COMPAT_INPUT_DISABLE)
+			current->compat_input = false;
+		else if (arg2 == PR_SET_COMPAT_INPUT_ENABLE)
+			current->compat_input = true;
+		else
+			return -EINVAL;
+		break;
 	default:
 		trace_task_prctl_unknown(option, arg2, arg3, arg4, arg5);
 		error = -EINVAL;
