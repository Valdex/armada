[Unit]
Description=armada SteamOS Manager compatibility service
After=armada-powerd.service
Requires=armada-powerd.service

[Service]
Type=dbus
BusName=com.steampowered.SteamOSManager1
ExecStart=/usr/libexec/armada/steamos-manager --system
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
